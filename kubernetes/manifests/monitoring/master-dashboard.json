      "id": 1,
      "panels": [],
      "title": "GLOBAL OVERVIEW (RED METRICS & CLUSTER HEALTH)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(rate(flask_http_request_duration_seconds_count[5m]))", "legendFormat": "Total RPS", "refId": "A" }
      ],
      "title": "Total Requests Per Second",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "sum(rate(flask_http_request_duration_seconds_sum{status_code=~'5..'}[5m])) / sum(rate(flask_http_request_duration_seconds_count[5m])) * 100", "legendFormat": "5xx Error Rate", "refId": "A" }
      ],
      "title": "Global 5xx Error Rate (%)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum(rate(flask_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P99 Latency", "refId": "A" }
      ],
      "title": "Global P99 Latency (s)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        { "expr": "sum(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / sum(node_memory_MemTotal_bytes) * 100", "refId": "A" }
      ],
      "title": "Cluster Memory Usage (%)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "panels": [],
      "title": "API GATEWAY & USER-FACING MICROSERVICES",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 11,
      "targets": [
        { "expr": "sum by (app) (rate(flask_http_request_duration_seconds_count[5m]))", "legendFormat": "{{app}} RPS", "refId": "A" },
        { "expr": "sum by (app) (rate(flask_http_request_duration_seconds_sum[5m]) / rate(flask_http_request_duration_seconds_count[5m]))", "legendFormat": "{{app}} Avg Latency", "refId": "B" }
      ],
      "title": "Requests and Latency per Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 12,
      "targets": [
        { "expr": "sum by (app, status_code) (rate(flask_http_request_duration_seconds_count{status_code=~'4..|5..'}[5m]))", "legendFormat": "{{app}} {{status_code}} Errors", "refId": "A" }
      ],
      "title": "Error Rates by Service & Status Code",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 20,
      "panels": [],
      "title": "BACKGROUND WORKERS (CONVERTER & NOTIFICATION)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 21,
      "targets": [
        { "expr": "sum by (queue) (rabbitmq_queue_messages)", "legendFormat": "{{queue}} Queue Size", "refId": "A" }
      ],
      "title": "RabbitMQ Queue Sizes",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 22,
      "targets": [
        { "expr": "sum by (worker) (rate(worker_tasks_processed_total[5m]))", "legendFormat": "{{worker}} Processed/s", "refId": "A" },
        { "expr": "sum by (worker) (rate(worker_tasks_failed_total[5m]))", "legendFormat": "{{worker}} Failed/s", "refId": "B" }
      ],
      "title": "Worker Task Processing & Failures",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 30,
      "panels": [],
      "title": "DEVSECOPS & SYSTEM STABILITY",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 31,
      "targets": [
        { "expr": "sum by (severity) (trivy_vulnerabilities{severity=~'CRITICAL|HIGH'})", "legendFormat": "{{severity}} Vulnerabilities", "refId": "A" }
      ],
      "title": "Trivy Critical/High Vulnerabilities Trend",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 32,
      "targets": [
        { "expr": "sum by (pod, namespace) (kube_pod_container_status_restarts_total)", "legendFormat": "Restarts: {{pod}}", "refId": "A" }
      ],
      "title": "Pod Restarts (Instability Detection)",
      "type": "timeseries"
    }
  ],
